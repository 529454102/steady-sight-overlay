{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "稳视 Overlay",
  "version": "0.1.0",
  "identifier": "com.steadysight.overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "稳视 Overlay",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "稳视 Overlay 层",
        "url": "overlay.html",
        "width": 1280,
        "height": 720,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
